# paths resolve relative to this file. piper voices live in <voices_dir>/piper/, kokoro downloads on demand
voices_dir: ../../voices
sounds_dir: ../../sounds

# piper | kokoro
backend: piper

# mp3 | wav
default_format: mp3

# loudnorm pass on rendered audio (loudnorm=I=-16:TP=-1.5:LRA=11)
normalize: false

max_text_chars: 500
max_concurrency: 2
max_sfx_per_request: 10

# "*" or comma-separated list of origins
cors_allow_origins: "*"

db_file: ./data/tts.db

# short prefixes mapped to voice ids, e.g. "ryan: hello" -> en_US-ryan-high
aliases: {}

# selected via the "preset" field or inline tags like "[fast] hello"
presets:
  fast:
    length_scale: 0.85
  slow:
    length_scale: 1.2

# post-synth DSP chain (pedalboard). stages: pitch_shift, bitcrush, chorus, reverb, gain, highpass, lowpass, distortion, delay, compressor
voice_fx:
  enabled: false
  chain: []

moderation:
  enabled: true
  strip_urls: true
  strip_emojis: true
  censor_slurs: true
  blocklist_path: ./mod_blocklist.txt

auth:
  enabled: true
  file: ./secrets.yaml

session:
  file: ./secrets.yaml
  # lax | strict | none
  same_site: lax
  # true when serving over HTTPS
  secure: false
